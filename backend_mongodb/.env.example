NODE_ENV=development
PORT=8082
MONGODB_URI=mongodb://127.0.0.1:27017/invito
JWT_SECRET=replace-with-a-secure-random-secret
BACKEND_URL=http://localhost:8082
FRONTEND_URL=http://localhost:5173

# Email / Mailgun
MAILGUN_USERNAME=api
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_URL=https://api.mailgun.net
MAILGUN_DOMAIN=mg.example.com
MAILGUN_EMAIL=no-reply@example.com

# Moyasar
MOYASAR_SECRET_KEY=your-moyasar-secret-key

# Meta / WhatsApp optional
META_WEBHOOK_VERIFY_TOKEN=replace-with-your-webhook-verify-token
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_CONFIGURATION_ID=your-meta-configuration-id
META_REDIRECT_URI=http://localhost:8082/api/event/auth/callback
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_APP_ID=your-whatsapp-app-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_EVENT_TEMPLATE_NAME_EN=event_invitation_en
WHATSAPP_EVENT_TEMPLATE_LANGUAGE_EN=en
WHATSAPP_EVENT_TEMPLATE_NAME_AR=event_invitation_ar
WHATSAPP_EVENT_TEMPLATE_LANGUAGE_AR=ar
WHATSAPP_EVENT_TEMPLATE_PARAM_1=guest_name
WHATSAPP_EVENT_TEMPLATE_PARAM_2=event_title
WHATSAPP_EVENT_TEMPLATE_PARAM_3=event_description
WHATSAPP_EVENT_TEMPLATE_PARAM_4=event_date
WHATSAPP_EVENT_TEMPLATE_PARAM_5=event_time
WHATSAPP_EVENT_TEMPLATE_PARAM_6=event_location
